def _normalize_market_provider(value: str | None) -> str:
    v = str(value or "auto").strip().lower()
    if v in {"tencent", "qq", "gtimg"}:
        return "tencent"
    if v in {"eastmoney", "em", "cn", "china", "mainland"}:
        return "eastmoney"
    if v in {"yfinance", "yf", "yahoo", "us"}:
        return "yfinance"
    return "auto"


